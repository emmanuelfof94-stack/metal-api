generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum ProjectType {
  DOOR
  GATE
  WINDOW_GRILL
  ROOF_FRAME
  METAL_BOX
  CUSTOM
}

enum ProjectStatus {
  LEAD
  MEASUREMENT_PENDING
  QUOTE_DRAFT
  QUOTE_SENT
  QUOTE_ACCEPTED
  IN_PRODUCTION
  READY_FOR_DELIVERY
  DELIVERED
  CLOSED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CHEQUE
  OTHER
}

enum PriceRuleType {
  FIXED
  PER_SQM
  PER_LINEAR_METER
  PER_UNIT
  FORMULA
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  address   String?
  notes     String?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                   String        @id @default(cuid())
  reference            String        @unique
  customerId           String
  customer             Customer      @relation(fields: [customerId], references: [id])
  type                 ProjectType
  title                String
  description          String?
  status               ProjectStatus @default(LEAD)
  widthM               Decimal?      @db.Decimal(10, 2)
  heightM              Decimal?      @db.Decimal(10, 2)
  lengthM              Decimal?      @db.Decimal(10, 2)
  areaM2               Decimal?      @db.Decimal(10, 2)
  quantity             Int           @default(1)
  specificationJson    Json?
  estimatedCost        Decimal?      @db.Decimal(14, 2)
  estimatedPrice       Decimal?      @db.Decimal(14, 2)
  actualCost           Decimal?      @db.Decimal(14, 2)
  actualRevenue        Decimal?      @db.Decimal(14, 2)
  desiredMarginPercent Decimal?      @db.Decimal(5, 2)
  measurementDate      DateTime?
  expectedDeliveryDate DateTime?
  quotes               Quote[]
  payments             Payment[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Quote {
  id               String      @id @default(cuid())
  projectId        String
  project          Project     @relation(fields: [projectId], references: [id])
  version          Int         @default(1)
  status           QuoteStatus @default(DRAFT)
  subtotalMaterial Decimal     @default(0) @db.Decimal(14, 2)
  subtotalLabor    Decimal     @default(0) @db.Decimal(14, 2)
  subtotalOther    Decimal     @default(0) @db.Decimal(14, 2)
  marginPercent    Decimal     @default(0) @db.Decimal(5, 2)
  marginAmount     Decimal     @default(0) @db.Decimal(14, 2)
  totalAmount      Decimal     @default(0) @db.Decimal(14, 2)
  notes            String?
  lines            QuoteLine[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model QuoteLine {
  id           String   @id @default(cuid())
  quoteId      String
  quote        Quote    @relation(fields: [quoteId], references: [id])
  label        String
  category     String
  unit         String?
  quantity     Decimal  @default(1) @db.Decimal(14, 2)
  unitPrice    Decimal  @default(0) @db.Decimal(14, 2)
  totalPrice   Decimal  @default(0) @db.Decimal(14, 2)
  computed     Boolean  @default(true)
  formulaCode  String?
  sortOrder    Int      @default(0)
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PricingItem {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  category        String
  unit            String
  ruleType        PriceRuleType
  unitPrice       Decimal       @default(0) @db.Decimal(14, 2)
  formulaTemplate String?
  active          Boolean       @default(true)
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Payment {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  amount    Decimal       @db.Decimal(14, 2)
  method    PaymentMethod
  paidAt    DateTime
  reference String?
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
